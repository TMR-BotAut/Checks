# ── LLM ──────────────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic          # anthropic | openai | mock
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
LLM_MODEL=claude-haiku-4-5-20251001   # default

# ── Busca web ─────────────────────────────────────────────────────────────────
SEARCH_PROVIDER=mock            # serpapi | tavily | nimble | mock
SERPAPI_KEY=
TAVILY_API_KEY=
NIMBLE_API_KEY=

# ── Dados externos ────────────────────────────────────────────────────────────
BRASILIO_API_TOKEN=             # token gratuito: brasil.io/auth/tokens-api

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000
